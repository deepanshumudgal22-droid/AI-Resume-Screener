# In[2]:


get_ipython().system('pip install pypdf python-docx scikit-learn pandas')
import os
import re
import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity


# In[3]:


def extract_text_from_txt(txt_path):
    with open(txt_path, 'r', encoding='utf-8', errors='ignore') as file:
        return file.read()


# In[4]:


def basic_clean(text):
    # 1. Convert to lowercase
    text = text.lower()
    # 2. Replace numbers and punctuation with spaces using regex
    text = re.sub(r'[^a-z\s]', ' ', text)
    # 3. Remove extra white spaces
    text = re.sub(r'\s+', ' ', text).strip()
    return text


# In[6]:


job_description = "Looking for a Data Scientist with Python, Machine Learning, and SQL skills."

mock_resumes = {
    "Candidate_A.pdf": "Data Scientist experienced in Python, Machine Learning, and SQL databases.",
    "Candidate_B.pdf": "Web Developer specializing in JavaScript, HTML, CSS, and React framework."
}

# Clean the data using our basic regex function
cleaned_jd = basic_clean(job_description)
cleaned_resumes = {name: basic_clean(text) for name, text in mock_resumes.items()}


# In[7]:


file_names = list(cleaned_resumes.keys())
corpus = [cleaned_jd] + list(cleaned_resumes.values())

# 'english' tells scikit-learn to handle stop-word removal internally!
vectorizer = TfidfVectorizer(stop_words='english')
tfidf_matrix = vectorizer.fit_transform(corpus)

# Calculate Cosine Similarity
jd_vector = tfidf_matrix[0]
resume_vectors = tfidf_matrix[1:]
similarity_scores = cosine_similarity(jd_vector, resume_vectors).flatten()

# Display Ranked Results
results_df = pd.DataFrame({
    'Candidate Resume': file_names,
    'Match Score (%)': np.round(similarity_scores * 100, 2)
}).sort_values(by='Match Score (%)', ascending=False).reset_index(drop=True)

results_df


